{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jumperscripts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "cloudflare/script-registry-worker/scripts"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
